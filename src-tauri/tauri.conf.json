{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aethon",
  "version": "0.8.1",
  "identifier": "com.utensils.aethon",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aethon",
        "width": 1200,
        "height": 800,
        "center": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 19 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "James Brink",
    "homepage": "https://github.com/utensils/aethon",
    "copyright": "Copyright © 2026 James Brink. MIT License.",
    "category": "DeveloperTool",
    "shortDescription": "pi with a face — agent-driven desktop shell.",
    "longDescription": "Aethon wraps the pi-coding-agent in a Tauri 2 desktop workspace where the agent renders its UI as A2UI components. The agent can mutate the layout in real time — registering sidebar sections, themes, and interactive panels via globalThis.aethon — making the entire window an extension surface, not just the chat.",
    "externalBin": ["binaries/aethon-agent"],
    "resources": {
      "binaries/pi/package.json": "pi/package.json",
      "../docs/aethon-agent/README.md": "docs/aethon-agent/README.md",
      "../docs/aethon-agent/api.md": "docs/aethon-agent/api.md",
      "../docs/aethon-agent/components.md": "docs/aethon-agent/components.md",
      "../docs/aethon-agent/extensions.md": "docs/aethon-agent/extensions.md",
      "../docs/aethon-agent/project-config.md": "docs/aethon-agent/project-config.md",
      "../src/extensions/default-layout/workstation.a2ui.json": "extensions/default-layout/workstation.a2ui.json",
      "../src/extensions/default-layout/slots.json": "extensions/default-layout/slots.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/utensils/aethon/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDRTNGQjM3RTg2ODU1MTgKUldRWVZXam9OL3ZqSEUwbWx0YjhyQ2NqN3VsRUd5Q1dPMzhkdFBiTUNnL1RNYUZVVzgrWmJqMm4K"
    }
  }
}
