# Project-internal
.aethon/

# Local-only signing/notarization secrets sourced by `build-app`.
# Never commit. See RELEASING.md for what's expected to be in here.
.secrets/

# Claude Code session state
.claude/worktrees/
.claude/scheduled_tasks.lock

# Node / Bun
node_modules/
dist/
*.log

# Rust / Tauri
target/
src-tauri/gen/schemas/
# Mobile companion: schemas are regenerated by tauri-build; the Xcode
# project (gen/apple) IS committed once `tauri ios init` runs on a Mac
# with CocoaPods (see docs/mobile.md), so it is not ignored here.
apps/mobile/src-tauri/gen/schemas/
dist-mobile/

# Compiled aethon-agent sidecar (per-platform, ~70 MB; rebuilt by
# scripts/build-agent.sh / `build-agent`). Holds platform-specific
# triples so each developer builds their own.
src-tauri/binaries/

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Nix
result
result-*
.direnv/
.envrc.local

# Coverage
*.profraw
*.profdata
lcov.info
coverage/
playwright-report/
test-results/

# Phase test harness and ad-hoc screenshots (local-only).
# Ignore all .png + .zip globally, then re-include the bundled Tauri
# app icons (which are tracked source assets).
.playwright-mcp/
/run-phase*.sh
*.png
*.zip
!src-tauri/icons/*.png
!apps/mobile/src-tauri/icons/*.png
!apps/mobile/src-tauri/gen/apple/Assets.xcassets/**/*.png
!assets/brand/aethon-app-screenshot.png
!website/public/*.png

# Local working notes — not for git.
/TODO.md

# VitePress build output (cache survives a clean checkout, dist is the
# Pages artifact). The lockfile under website/ is committed.
website/.vitepress/cache/
website/.vitepress/dist/
website/node_modules/
