{
  "components": [
    {
      "id": "root-layout",
      "type": "layout",
      "props": {
        "columns": { "$ref": "/layout/columns" },
        "rows": { "$ref": "/layout/rows" },
        "areas": { "$ref": "/layout/areas" },
        "slotMap": { "empty-state": "canvas" }
      },
      "children": [
        {
          "id": "header",
          "type": "container",
          "props": {
            "area": "header",
            "direction": "row",
            "align": "center",
            "gap": 12,
            "padding": 0,
            "className": "app-header ae-tight",
            "dragRegion": true
          },
          "children": [
            {
              "id": "header-pill",
              "type": "agent-pulse",
              "props": {
                "label": { "$ref": "/agentStatus/label" },
                "state": { "$ref": "/agentStatus/state" }
              }
            },
            {
              "id": "header-vcs",
              "type": "vcs-status",
              "props": { "source": { "$ref": "/vcs" } }
            },
            {
              "id": "header-spacer",
              "type": "container",
              "props": {
                "direction": "row",
                "className": "ae-header-spacer"
              }
            },
            {
              "id": "model-picker",
              "type": "model-picker",
              "props": {}
            },
            {
              "id": "appearance-menu",
              "type": "appearance-menu",
              "props": {}
            }
          ]
        },
        {
          "id": "header-tabs",
          "type": "tab-strip",
          "props": {
            "area": "tabs",
            "tabs": { "$ref": "/tabs" },
            "activeId": { "$ref": "/activeTabId" }
          }
        },
        {
          "id": "sidebar-area",
          "type": "container",
          "props": {
            "area": "sidebar",
            "direction": "column",
            "gap": 0,
            "padding": 0,
            "className": "ae-sidebar-area",
            "visible": { "$ref": "/layout/sidebarVisible" }
          },
          "children": [
            {
              "id": "sidebar",
              "type": "sidebar",
              "props": {
                "version": { "$ref": "/appVersion" },
                "brandMark": true,
                "hostGroups": true,
                "hosts": { "$ref": "/sidebar/hosts" },
                "sections": [
                  {
                    "id": "projects",
                    "title": "projects",
                    "items": { "$ref": "/sidebar/projects" },
                    "actions": [
                      { "id": "open-project", "label": "Open project…" }
                    ]
                  }
                ],
                "extraSections": { "$ref": "/sidebar/extraSections" }
              }
            }
          ]
        },
        {
          "id": "files-sidebar-area",
          "type": "container",
          "props": {
            "area": "files-sidebar",
            "direction": "column",
            "gap": 0,
            "padding": 0,
            "className": "ae-files-sidebar-area",
            "visible": { "$ref": "/layout/filesSidebarVisible" }
          },
          "children": [
            {
              "id": "source-control-panel",
              "type": "source-control-panel",
              "props": { "source": { "$ref": "/vcs" } }
            },
            {
              "id": "file-tree",
              "type": "file-tree",
              "props": {
                "embed": "right-sidebar"
              }
            }
          ]
        },
        {
          "id": "main-canvas",
          "type": "main-canvas",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/agentTabActive" },
            "slot": "/canvas",
            "messages": { "$ref": "/messages" }
          }
        },
        {
          "id": "editor-canvas",
          "type": "editor-canvas",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/editorTabActive" },
            "tabId": { "$ref": "/activeTabId" }
          }
        },
        {
          "id": "projects-dashboard",
          "type": "projects-dashboard",
          "props": {
            "area": "empty-state",
            "visible": { "$ref": "/emptyAndNoProject" },
            "projects": { "$ref": "/projects" },
            "recentSessions": { "$ref": "/recentSessions" },
            "extraCards": { "$ref": "/projectsDashboard/extraCards" },
            "host": { "$ref": "/host" }
          }
        },
        {
          "id": "project-dashboard",
          "type": "project-dashboard",
          "props": {
            "area": "empty-state",
            "visible": { "$ref": "/emptyAndProject" },
            "project": { "$ref": "/project" },
            "otherProjects": { "$ref": "/projectDashboard/otherProjects" },
            "workspaces": { "$ref": "/projectDashboard/workspaces" },
            "activeWorkspaceId": { "$ref": "/activeWorkspaceId" },
            "recentSessions": { "$ref": "/projectDashboard/recentSessions" },
            "widgets": { "$ref": "/projectDashboard/widgets" }
          }
        },
        {
          "id": "workspace-landing",
          "type": "workspace-landing",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/landingVisible" },
            "landing": { "$ref": "/landing" },
            "recentSessions": { "$ref": "/recentSessions" }
          }
        },
        {
          "id": "terminal-panel",
          "type": "terminal-panel",
          "props": {
            "area": "terminal",
            "visible": { "$ref": "/terminal/open" },
            "fontSize": 13
          }
        },
        {
          "id": "composer-area",
          "type": "container",
          "props": {
            "area": "composer",
            "visible": { "$ref": "/agentTabActive" },
            "direction": "column",
            "gap": 0,
            "className": "ae-composer-area"
          },
          "children": [
            {
              "id": "composer-visibility-pills",
              "type": "composer-visibility-pills",
              "props": {}
            },
            {
              "id": "chat-input",
              "type": "chat-input",
              "props": {
                "value": { "$ref": "/draft" },
                "placeholder": "Message Aethon… (@<subagent> to delegate, @file for context, / for commands)",
                "disabled": { "$ref": "/waiting" },
                "planMode": { "$ref": "/planMode" },
                "queueCount": { "$ref": "/queueCount" },
                "commands": { "$ref": "/slashCommands" },
                "onSubmit": "chat:send"
              }
            }
          ]
        },
        {
          "id": "status-bar",
          "type": "status-bar",
          "props": {
            "area": "status",
            "left": { "$ref": "/status" },
            "center": { "$ref": "/connection" },
            "right": { "$ref": "/model" },
            "context": { "$ref": "/contextUsage" }
          }
        }
      ]
    }
  ],
  "state": {
    "status": "starting…",
    "connection": "disconnected",
    "model": "—",
    "contextUsage": null,
    "draft": "",
    "waiting": false,
    "planMode": false,
    "queueCount": 0,
    "queuedMessages": [],
    "messages": [],
    "canvas": null,
    "activeTabId": "__overview__",
    "empty": true,
    "hasTabs": false,
    "hasSessionTabs": false,
    "overviewActive": true,
    "overviewTabId": "__overview__",
    "agentTabActive": false,
    "shellTabActive": false,
    "editorTabActive": false,
    "landingVisible": false,
    "landing": null,
    "recentSessions": [],
    "agentStatus": {
      "label": "agent live",
      "state": "live"
    },
    "layout": {
      "sidebarVisible": true,
      "filesSidebarVisible": true,
      "columns": "320px minmax(0,1fr) 360px",
      "rows": "38px 38px minmax(0,1fr) 0px auto auto",
      "areas": [
        "sidebar header files-sidebar",
        "sidebar tabs files-sidebar",
        "sidebar canvas files-sidebar",
        "sidebar terminal files-sidebar",
        "sidebar composer files-sidebar",
        "status status status"
      ]
    },
    "sidebar": {
      "history": [],
      "models": [],
      "hosts": [],
      "projects": [],
      "extensions": [],
      "extraSections": [],
      "themes": [
        {
          "id": "ember",
          "label": "Ember — deep warm dark, glowing brass",
          "active": true
        },
        { "id": "paper", "label": "Paper — crisp neutral light" },
        { "id": "aether", "label": "Æther — deep cosmic ink-blue" },
        {
          "id": "brink",
          "label": "Brink — warm chrome with slate wash + gold"
        },
        { "id": "daylight", "label": "Daylight — warm golden light" },
        { "id": "mist", "label": "Mist — cool teal light" },
        { "id": "nocturne", "label": "Nocturne — neon navy, cyan + magenta" }
      ]
    },
    "projects": [],
    "activeProjectId": null,
    "project": null,
    "hosts": [],
    "activeHostId": null,
    "host": null,
    "terminal": {
      "open": false
    },
    "terminalPanel": {
      "activeSubId": "agent-bash"
    },
    "vcs": {
      "root": null,
      "branch": null,
      "ahead": 0,
      "behind": 0,
      "dirty": false,
      "ghAvailable": false,
      "loading": false,
      "changes": {
        "total": 0,
        "modified": 0,
        "added": 0,
        "deleted": 0,
        "untracked": 0,
        "renamed": 0,
        "copied": 0,
        "conflicted": 0,
        "files": []
      },
      "pr": null,
      "ci": null
    },
    "slashCommands": []
  }
}
