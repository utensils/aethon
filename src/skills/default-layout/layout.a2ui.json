{
  "components": [
    {
      "id": "root-layout",
      "type": "layout",
      "props": {
        "columns": "240px 1fr",
        "rows": "auto 1fr auto auto auto",
        "areas": [
          "sidebar header",
          "sidebar canvas",
          "sidebar terminal",
          "sidebar chat-input",
          "status status"
        ]
      },
      "children": [
        {
          "id": "header",
          "type": "container",
          "props": {
            "area": "header",
            "direction": "row",
            "align": "center",
            "justify": "space-between",
            "padding": 12,
            "className": "app-header"
          },
          "children": [
            {
              "id": "header-title",
              "type": "text",
              "props": {
                "content": "Aethon",
                "variant": "large"
              }
            },
            {
              "id": "header-status",
              "type": "text",
              "props": {
                "content": { "$ref": "/status" },
                "variant": "small",
                "color": "var(--text-dim)"
              }
            }
          ]
        },
        {
          "id": "sidebar",
          "type": "sidebar",
          "props": {
            "area": "sidebar",
            "title": "Aethon",
            "sections": [
              {
                "id": "files",
                "title": "Files",
                "items": [
                  { "id": "file-spec", "label": "SPEC.md" },
                  { "id": "file-readme", "label": "README.md" },
                  { "id": "file-app", "label": "src/App.tsx" }
                ]
              },
              {
                "id": "skills",
                "title": "Skills",
                "items": [
                  { "id": "skill-layout", "label": "default-layout" }
                ]
              },
              {
                "id": "panels",
                "title": "Panels",
                "items": [
                  { "id": "toggle-terminal", "label": "Toggle Terminal" },
                  { "id": "clear-chat", "label": "Clear Chat" }
                ]
              },
              {
                "id": "models",
                "title": "Models",
                "items": { "$ref": "/sidebar/models" }
              },
              {
                "id": "themes",
                "title": "Themes",
                "items": [
                  { "id": "dark", "label": "Dark" },
                  { "id": "light", "label": "Light" }
                ]
              },
              {
                "id": "history",
                "title": "Chat History",
                "items": { "$ref": "/sidebar/history" }
              }
            ]
          }
        },
        {
          "id": "main-canvas",
          "type": "main-canvas",
          "props": {
            "area": "canvas",
            "slot": "/canvas",
            "messages": { "$ref": "/messages" }
          }
        },
        {
          "id": "terminal",
          "type": "terminal",
          "props": {
            "area": "terminal",
            "visible": { "$ref": "/terminal/open" },
            "fontSize": 13,
            "subscribeToBash": true,
            "onInput": "terminal:input"
          }
        },
        {
          "id": "chat-input",
          "type": "chat-input",
          "props": {
            "area": "chat-input",
            "value": { "$ref": "/draft" },
            "placeholder": "Message Aethon… (Enter to send, Shift+Enter for newline, / for commands)",
            "disabled": { "$ref": "/waiting" },
            "commands": { "$ref": "/slashCommands" },
            "onSubmit": "chat:send"
          }
        },
        {
          "id": "status-bar",
          "type": "status-bar",
          "props": {
            "area": "status",
            "left": { "$ref": "/status" },
            "center": { "$ref": "/connection" },
            "right": { "$ref": "/model" }
          }
        }
      ]
    }
  ],
  "state": {
    "status": "starting…",
    "connection": "disconnected",
    "model": "—",
    "draft": "",
    "waiting": false,
    "messages": [],
    "canvas": null,
    "sidebar": {
      "history": [],
      "models": []
    },
    "terminal": {
      "open": false
    },
    "slashCommands": []
  }
}
