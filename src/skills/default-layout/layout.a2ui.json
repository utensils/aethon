{
  "components": [
    {
      "id": "root-layout",
      "type": "layout",
      "props": {
        "columns": "240px 1fr",
        "rows": "auto auto 1fr auto auto auto",
        "areas": [
          "sidebar header",
          "sidebar tabs",
          "sidebar canvas",
          "sidebar terminal",
          "sidebar chat-input",
          "status status"
        ]
      },
      "children": [
        {
          "id": "header",
          "type": "container",
          "props": {
            "area": "header",
            "direction": "row",
            "align": "center",
            "justify": "space-between",
            "padding": 12,
            "className": "app-header"
          },
          "children": [
            {
              "id": "header-brand",
              "type": "container",
              "props": {
                "direction": "row",
                "align": "center",
                "gap": 10,
                "className": "app-header-brand"
              },
              "children": [
                {
                  "id": "header-logo",
                  "type": "image",
                  "props": {
                    "src": { "$ref": "/logoUrl" },
                    "alt": "Aethon",
                    "className": "app-header-logo"
                  }
                },
                {
                  "id": "header-title",
                  "type": "text",
                  "props": {
                    "content": "Aethon",
                    "variant": "large"
                  }
                }
              ]
            },
            {
              "id": "header-status",
              "type": "text",
              "props": {
                "content": { "$ref": "/status" },
                "variant": "small",
                "color": "var(--text-dim)"
              }
            }
          ]
        },
        {
          "id": "sidebar",
          "type": "sidebar",
          "props": {
            "area": "sidebar",
            "title": "Aethon",
            "sections": [
              {
                "id": "skills",
                "title": "Skills",
                "items": [
                  { "id": "skill-layout", "label": "default-layout" }
                ]
              },
              {
                "id": "panels",
                "title": "Panels",
                "items": [
                  { "id": "toggle-terminal", "label": "Toggle Terminal" },
                  { "id": "clear-chat", "label": "Clear Chat" }
                ]
              },
              {
                "id": "models",
                "title": "Models",
                "items": { "$ref": "/sidebar/models" }
              },
              {
                "id": "themes",
                "title": "Themes",
                "items": { "$ref": "/sidebar/themes" }
              },
              {
                "id": "history",
                "title": "Chat History",
                "items": { "$ref": "/sidebar/history" }
              }
            ],
            "extraSections": { "$ref": "/sidebar/extraSections" }
          }
        },
        {
          "id": "tab-strip",
          "type": "tab-strip",
          "props": {
            "area": "tabs",
            "visible": { "$ref": "/hasTabs" },
            "tabs": { "$ref": "/tabs" },
            "activeId": { "$ref": "/activeTabId" }
          }
        },
        {
          "id": "main-canvas",
          "type": "main-canvas",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/hasTabs" },
            "slot": "/canvas",
            "messages": { "$ref": "/messages" }
          }
        },
        {
          "id": "empty-state",
          "type": "empty-state",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/empty" },
            "title": "Welcome to Aethon",
            "subtitle": "All tabs are closed. Open a new one to start a conversation.",
            "primaryButtonLabel": "New Tab",
            "recentSessions": { "$ref": "/recentSessions" },
            "tips": [
              "Press ⌘T to open a new conversation tab.",
              "Type / in the composer to see slash commands.",
              "Run /skills to see what extensions are loaded."
            ]
          }
        },
        {
          "id": "terminal",
          "type": "terminal",
          "props": {
            "area": "terminal",
            "visible": { "$ref": "/terminal/open" },
            "fontSize": 13,
            "subscribeToBash": true,
            "readOnly": true
          }
        },
        {
          "id": "chat-input",
          "type": "chat-input",
          "props": {
            "area": "chat-input",
            "visible": { "$ref": "/hasTabs" },
            "value": { "$ref": "/draft" },
            "placeholder": "Message Aethon… (Enter to send, Shift+Enter for newline, / for commands)",
            "disabled": { "$ref": "/waiting" },
            "queueCount": { "$ref": "/queueCount" },
            "commands": { "$ref": "/slashCommands" },
            "onSubmit": "chat:send"
          }
        },
        {
          "id": "status-bar",
          "type": "status-bar",
          "props": {
            "area": "status",
            "left": { "$ref": "/status" },
            "center": { "$ref": "/connection" },
            "right": { "$ref": "/model" }
          }
        }
      ]
    }
  ],
  "state": {
    "status": "starting…",
    "connection": "disconnected",
    "model": "—",
    "draft": "",
    "waiting": false,
    "queueCount": 0,
    "messages": [],
    "canvas": null,
    "empty": false,
    "hasTabs": true,
    "recentSessions": [],
    "sidebar": {
      "history": [],
      "models": [],
      "extraSections": [],
      "themes": [
        { "id": "dark", "label": "Dark" },
        { "id": "light", "label": "Light" }
      ]
    },
    "terminal": {
      "open": false
    },
    "slashCommands": []
  }
}
