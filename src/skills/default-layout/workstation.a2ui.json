{
  "components": [
    {
      "id": "root-layout",
      "type": "layout",
      "props": {
        "columns": { "$ref": "/layout/columns" },
        "rows": { "$ref": "/layout/rows" },
        "areas": { "$ref": "/layout/areas" },
        "slotMap": { "empty-state": "canvas" }
      },
      "children": [
        {
          "id": "header",
          "type": "container",
          "props": {
            "area": "header",
            "direction": "row",
            "align": "center",
            "gap": 12,
            "padding": 0,
            "className": "app-header ae-tight"
          },
          "children": [
            {
              "id": "header-pill",
              "type": "agent-pulse",
              "props": {
                "label": { "$ref": "/agentStatus/label" },
                "state": { "$ref": "/agentStatus/state" }
              }
            },
            {
              "id": "header-spacer",
              "type": "container",
              "props": { "direction": "row", "className": "ae-header-spacer" }
            },
            {
              "id": "model-picker",
              "type": "model-picker",
              "props": {}
            },
            {
              "id": "appearance-menu",
              "type": "appearance-menu",
              "props": {}
            }
          ]
        },
        {
          "id": "header-tabs",
          "type": "tab-strip",
          "props": {
            "area": "tabs",
            "visible": { "$ref": "/hasTabs" },
            "tabs": { "$ref": "/tabs" },
            "activeId": { "$ref": "/activeTabId" }
          }
        },
        {
          "id": "sidebar-area",
          "type": "container",
          "props": {
            "area": "sidebar",
            "direction": "column",
            "gap": 0,
            "padding": 0,
            "className": "ae-sidebar-area",
            "visible": { "$ref": "/layout/sidebarVisible" }
          },
          "children": [
            {
              "id": "sidebar",
              "type": "sidebar",
              "props": {
                "title": "aethon",
                "version": { "$ref": "/appVersion" },
                "brandMark": true,
                "sections": [
                  {
                    "id": "hosts",
                    "title": "",
                    "items": { "$ref": "/sidebar/hosts" }
                  },
                  {
                    "id": "projects",
                    "title": "projects",
                    "items": { "$ref": "/sidebar/projects" },
                    "actions": [
                      { "id": "open-project", "label": "Open project…" }
                    ]
                  },
                  {
                    "id": "extensions",
                    "title": "extensions",
                    "items": { "$ref": "/sidebar/extensions" },
                    "hideWhenEmpty": true
                  }
                ],
                "extraSections": { "$ref": "/sidebar/extraSections" }
              }
            }
          ]
        },
        {
          "id": "files-sidebar-area",
          "type": "container",
          "props": {
            "area": "files-sidebar",
            "direction": "column",
            "gap": 0,
            "padding": 0,
            "className": "ae-files-sidebar-area",
            "visible": { "$ref": "/layout/filesSidebarVisible" }
          },
          "children": [
            {
              "id": "file-tree",
              "type": "file-tree",
              "props": {
                "embed": "right-sidebar"
              }
            }
          ]
        },
        {
          "id": "main-canvas",
          "type": "main-canvas",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/agentTabActive" },
            "slot": "/canvas",
            "messages": { "$ref": "/messages" }
          }
        },
        {
          "id": "editor-canvas",
          "type": "editor-canvas",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/editorTabActive" },
            "tabId": { "$ref": "/activeTabId" }
          }
        },
        {
          "id": "projects-dashboard",
          "type": "projects-dashboard",
          "props": {
            "area": "empty-state",
            "visible": { "$ref": "/emptyAndNoProject" },
            "projects": { "$ref": "/projects" },
            "recentSessions": { "$ref": "/recentSessions" },
            "extraCards": { "$ref": "/projectsDashboard/extraCards" },
            "host": { "$ref": "/host" }
          }
        },
        {
          "id": "project-dashboard",
          "type": "project-dashboard",
          "props": {
            "area": "empty-state",
            "visible": { "$ref": "/emptyAndProject" },
            "project": { "$ref": "/project" },
            "otherProjects": { "$ref": "/projectDashboard/otherProjects" },
            "worktrees": { "$ref": "/projectDashboard/worktrees" },
            "activeWorktreeId": { "$ref": "/activeWorktreeId" },
            "recentSessions": { "$ref": "/projectDashboard/recentSessions" },
            "widgets": { "$ref": "/projectDashboard/widgets" }
          }
        },
        {
          "id": "worktree-landing",
          "type": "worktree-landing",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/landingVisible" },
            "landing": { "$ref": "/landing" }
          }
        },
        {
          "id": "terminal-panel",
          "type": "terminal-panel",
          "props": {
            "area": "terminal",
            "visible": { "$ref": "/terminal/open" },
            "fontSize": 13
          }
        },
        {
          "id": "chat-input",
          "type": "chat-input",
          "props": {
            "area": "composer",
            "visible": { "$ref": "/agentTabActive" },
            "value": { "$ref": "/draft" },
            "placeholder": "Message Aethon… (Enter to send, Shift+Enter for newline, / for commands)",
            "disabled": { "$ref": "/waiting" },
            "queueCount": { "$ref": "/queueCount" },
            "commands": { "$ref": "/slashCommands" },
            "onSubmit": "chat:send"
          }
        },
        {
          "id": "status-bar",
          "type": "status-bar",
          "props": {
            "area": "status",
            "left": { "$ref": "/status" },
            "center": { "$ref": "/connection" },
            "right": { "$ref": "/model" }
          }
        }
      ]
    }
  ],
  "state": {
    "status": "starting…",
    "connection": "disconnected",
    "model": "—",
    "draft": "",
    "waiting": false,
    "queueCount": 0,
    "messages": [],
    "canvas": null,
    "empty": false,
    "hasTabs": true,
    "agentTabActive": true,
    "shellTabActive": false,
    "editorTabActive": false,
    "landingVisible": false,
    "landing": null,
    "recentSessions": [],
    "agentStatus": {
      "label": "agent live",
      "state": "live"
    },
    "layout": {
      "sidebarVisible": true,
      "filesSidebarVisible": true,
      "columns": "220px minmax(0,1fr) 360px",
      "rows": "38px 38px minmax(0,1fr) 0px auto auto",
      "areas": [
        "sidebar header files-sidebar",
        "sidebar tabs files-sidebar",
        "sidebar canvas files-sidebar",
        "sidebar terminal files-sidebar",
        "sidebar composer files-sidebar",
        "status status status"
      ]
    },
    "sidebar": {
      "history": [],
      "models": [],
      "hosts": [],
      "projects": [],
      "extensions": [],
      "extraSections": [],
      "themes": [
        { "id": "ember", "label": "Ember — warm dark", "active": true },
        { "id": "paper", "label": "Paper — cream light" },
        { "id": "aether", "label": "Æther — signature" },
        { "id": "brink", "label": "Brink — Ristretto warm chrome with gold accent" }
      ]
    },
    "projects": [],
    "activeProjectId": null,
    "project": null,
    "hosts": [],
    "activeHostId": null,
    "host": null,
    "terminal": {
      "open": false
    },
    "terminalPanel": {
      "activeSubId": "agent-bash"
    },
    "slashCommands": []
  }
}
