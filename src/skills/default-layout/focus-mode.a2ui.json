{
  "components": [
    {
      "id": "root-layout",
      "type": "layout",
      "props": {
        "columns": "1fr",
        "rows": "1fr auto auto",
        "areas": [
          "canvas",
          "composer",
          "status"
        ]
      },
      "children": [
        {
          "id": "main-canvas",
          "type": "main-canvas",
          "props": {
            "area": "canvas",
            "slot": "/canvas",
            "messages": { "$ref": "/messages" },
            "emptyHint": "Focus mode — just you and the agent."
          }
        },
        {
          "id": "chat-input",
          "type": "chat-input",
          "props": {
            "area": "composer",
            "value": { "$ref": "/draft" },
            "placeholder": "Message Aethon…",
            "disabled": { "$ref": "/waiting" },
            "queueCount": { "$ref": "/queueCount" },
            "commands": { "$ref": "/slashCommands" },
            "onSubmit": "chat:send"
          }
        },
        {
          "id": "status-bar",
          "type": "status-bar",
          "props": {
            "area": "status",
            "left": { "$ref": "/status" },
            "center": { "$ref": "/connection" },
            "right": { "$ref": "/model" }
          }
        }
      ]
    }
  ],
  "state": {
    "status": "focus mode",
    "connection": "connected",
    "model": "—",
    "draft": "",
    "waiting": false,
    "queueCount": 0,
    "messages": [],
    "canvas": null,
    "slashCommands": []
  }
}
