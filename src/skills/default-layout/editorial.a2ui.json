{
  "components": [
    {
      "id": "root-layout",
      "type": "layout",
      "props": {
        "columns": "54px 1fr",
        "rows": "52px 1fr auto auto auto",
        "areas": [
          "spine header",
          "spine canvas",
          "spine terminal",
          "spine composer",
          "spine status"
        ],
        "slotMap": { "sidebar": "spine" },
        "className": "ae-editorial"
      },
      "children": [
        {
          "id": "spine",
          "type": "brand-spine",
          "props": {
            "area": "sidebar",
            "title": "ÆTHON · π"
          }
        },
        {
          "id": "header",
          "type": "container",
          "props": {
            "area": "header",
            "direction": "row",
            "align": "center",
            "gap": 12,
            "padding": 0,
            "className": "ae-editorial-header-row"
          },
          "children": [
            {
              "id": "editorial-header-inner",
              "type": "editorial-header",
              "props": {
                "title": "Æthon π",
                "subtitle": { "$ref": "/sessionLabel" },
                "tabs": { "$ref": "/tabs" },
                "activeId": { "$ref": "/activeTabId" }
              }
            },
            {
              "id": "header-spacer",
              "type": "container",
              "props": { "direction": "row", "className": "ae-header-spacer" }
            },
            {
              "id": "model-picker",
              "type": "model-picker",
              "props": {}
            },
            {
              "id": "appearance-menu",
              "type": "appearance-menu",
              "props": {}
            }
          ]
        },
        {
          "id": "main-canvas",
          "type": "main-canvas",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/hasTabs" },
            "slot": "/canvas",
            "messages": { "$ref": "/messages" }
          }
        },
        {
          "id": "empty-state",
          "type": "empty-state",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/empty" },
            "title": "Æthon awaits.",
            "subtitle": "Open a chapter to begin a session.",
            "primaryButtonLabel": "New Chapter",
            "recentSessions": { "$ref": "/recentSessions" },
            "tips": [
              "Press ⌘T to open a new conversation chapter.",
              "Type / in the composer to see slash commands."
            ]
          }
        },
        {
          "id": "terminal",
          "type": "terminal",
          "props": {
            "area": "terminal",
            "visible": { "$ref": "/terminal/open" },
            "fontSize": 13,
            "subscribeToBash": true,
            "readOnly": true
          }
        },
        {
          "id": "chat-input",
          "type": "chat-input",
          "props": {
            "area": "composer",
            "visible": { "$ref": "/hasTabs" },
            "value": { "$ref": "/draft" },
            "placeholder": "Speak to Æthon…",
            "disabled": { "$ref": "/waiting" },
            "queueCount": { "$ref": "/queueCount" },
            "commands": { "$ref": "/slashCommands" },
            "onSubmit": "chat:send"
          }
        },
        {
          "id": "status-bar",
          "type": "status-bar",
          "props": {
            "area": "status",
            "left": { "$ref": "/status" },
            "center": { "$ref": "/connection" },
            "right": { "$ref": "/model" }
          }
        }
      ]
    }
  ],
  "state": {
    "status": "starting…",
    "connection": "disconnected",
    "model": "—",
    "draft": "",
    "waiting": false,
    "queueCount": 0,
    "messages": [],
    "canvas": null,
    "empty": false,
    "hasTabs": true,
    "recentSessions": [],
    "sessionLabel": "",
    "projects": [],
    "activeProjectId": null,
    "project": null,
    "layout": {
      "sidebarVisible": true
    },
    "sidebar": {
      "history": [],
      "models": [],
      "projects": [],
      "extraSections": [],
      "themes": [
        { "id": "ember", "label": "Ember — warm dark", "active": true },
        { "id": "paper", "label": "Paper — cream light" },
        { "id": "aether", "label": "Æther — signature" }
      ]
    },
    "terminal": {
      "open": false
    },
    "slashCommands": []
  }
}
