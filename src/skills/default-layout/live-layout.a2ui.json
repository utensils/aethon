{
  "components": [
    {
      "id": "root-layout",
      "type": "layout",
      "props": {
        "columns": "244px 1fr 280px",
        "rows": "44px 1fr auto auto auto",
        "areas": [
          "sidebar header inspector",
          "sidebar canvas inspector",
          "sidebar terminal inspector",
          "sidebar composer inspector",
          "status status status"
        ]
      },
      "children": [
        {
          "id": "sidebar",
          "type": "sidebar",
          "props": {
            "area": "sidebar",
            "visible": { "$ref": "/layout/sidebarVisible" },
            "title": "aethon",
            "brandMark": true,
            "sections": [
              {
                "id": "projects",
                "title": "projects",
                "items": { "$ref": "/sidebar/projects" },
                "actions": [
                  { "id": "open-project", "label": "Open project…" }
                ]
              },
              {
                "id": "layouts",
                "title": "layouts",
                "monoItems": true,
                "items": { "$ref": "/sidebar/layouts" }
              },
              {
                "id": "tabs",
                "title": "tabs",
                "items": { "$ref": "/sidebar/tabsAsItems" }
              },
              {
                "id": "components",
                "title": "components in layout",
                "monoItems": true,
                "items": { "$ref": "/sidebar/components" }
              },
              {
                "id": "themes",
                "title": "themes",
                "monoItems": true,
                "items": { "$ref": "/sidebar/themes" }
              }
            ],
            "extraSections": { "$ref": "/sidebar/extraSections" }
          }
        },
        {
          "id": "header",
          "type": "container",
          "props": {
            "area": "header",
            "direction": "row",
            "align": "center",
            "gap": 10,
            "padding": 10,
            "className": "app-header"
          },
          "children": [
            {
              "id": "tab-strip",
              "type": "tab-strip",
              "props": {
                "visible": { "$ref": "/hasTabs" },
                "tabs": { "$ref": "/tabs" },
                "activeId": { "$ref": "/activeTabId" }
              }
            },
            {
              "id": "live-pill",
              "type": "layout-change-pill",
              "props": {
                "label": { "$ref": "/livePill/text" },
                "visible": { "$ref": "/livePill/visible" }
              }
            }
          ]
        },
        {
          "id": "main-canvas",
          "type": "main-canvas",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/hasTabs" },
            "slot": "/canvas",
            "messages": { "$ref": "/messages" }
          }
        },
        {
          "id": "layout-toast",
          "type": "layout-diff-toast",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/livePill/toastVisible" },
            "title": { "$ref": "/livePill/title" },
            "diff": { "$ref": "/livePill/diff" },
            "when": { "$ref": "/livePill/when" },
            "meta": "layout.a2ui.json"
          }
        },
        {
          "id": "empty-state",
          "type": "empty-state",
          "props": {
            "area": "canvas",
            "visible": { "$ref": "/empty" },
            "title": "Live layout",
            "subtitle": "The agent rearranges its own UI here. Open a tab to see it in motion.",
            "primaryButtonLabel": "New Tab",
            "recentSessions": { "$ref": "/recentSessions" }
          }
        },
        {
          "id": "inspector",
          "type": "inspector-pane",
          "props": {
            "area": "inspector",
            "title": "Inspector",
            "badge": "live",
            "layoutSummary": "{\n  \"rows\": \"44px 1fr 22px\",\n  \"cols\": \"244 1fr 280\",\n  \"areas\": [\n    \"sidebar  header  inspector\",\n    \"sidebar  canvas  inspector\",\n    \"status   status  status\"\n  ]\n}",
            "stateRows": [
              { "label": "messages", "value": { "$ref": "/inspector/messageCount" } },
              { "label": "tab", "value": { "$ref": "/activeTabId" } },
              { "label": "model", "value": { "$ref": "/model" } }
            ],
            "ops": { "$ref": "/inspector/ops" }
          }
        },
        {
          "id": "terminal",
          "type": "terminal",
          "props": {
            "area": "terminal",
            "visible": { "$ref": "/terminal/open" },
            "fontSize": 13,
            "subscribeToBash": true,
            "readOnly": true
          }
        },
        {
          "id": "chat-input",
          "type": "chat-input",
          "props": {
            "area": "composer",
            "visible": { "$ref": "/hasTabs" },
            "value": { "$ref": "/draft" },
            "placeholder": "prompt the layout…",
            "disabled": { "$ref": "/waiting" },
            "queueCount": { "$ref": "/queueCount" },
            "commands": { "$ref": "/slashCommands" },
            "onSubmit": "chat:send"
          }
        },
        {
          "id": "status-bar",
          "type": "status-bar",
          "props": {
            "area": "status",
            "left": { "$ref": "/status" },
            "center": { "$ref": "/connection" },
            "right": { "$ref": "/model" }
          }
        }
      ]
    }
  ],
  "state": {
    "status": "starting…",
    "connection": "disconnected",
    "model": "—",
    "draft": "",
    "waiting": false,
    "queueCount": 0,
    "messages": [],
    "canvas": null,
    "empty": false,
    "hasTabs": true,
    "recentSessions": [],
    "livePill": {
      "text": "",
      "title": "",
      "diff": "",
      "when": "",
      "visible": false,
      "toastVisible": false
    },
    "inspector": {
      "messageCount": "0",
      "ops": []
    },
    "projects": [],
    "activeProjectId": null,
    "project": null,
    "layout": {
      "sidebarVisible": true
    },
    "sidebar": {
      "history": [],
      "models": [],
      "projects": [],
      "components": [],
      "extraSections": [],
      "layouts": [
        { "id": "workstation", "label": "workstation", "active": true },
        { "id": "editorial", "label": "editorial" },
        { "id": "command-deck", "label": "command-deck" },
        { "id": "live-layout", "label": "live-layout" }
      ],
      "tabsAsItems": [],
      "themes": [
        { "id": "ember", "label": "Ember — warm dark", "active": true },
        { "id": "paper", "label": "Paper — cream light" },
        { "id": "aether", "label": "Æther — signature" }
      ]
    },
    "terminal": {
      "open": false
    },
    "slashCommands": []
  }
}
