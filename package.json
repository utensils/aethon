{
  "name": "aethon",
  "private": true,
  "version": "0.12.0",
  "type": "module",
  "bin": {
    "aethonctl": "./cli/aethonctl.ts"
  },
  "scripts": {
    "aethonctl": "bun cli/aethonctl.ts",
    "dev": "vite",
    "dev:mobile": "vite --config vite.mobile.config.ts",
    "build": "bun run version:check && tsc -b && vite build",
    "build:mobile": "tsc -b && vite build --config vite.mobile.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
