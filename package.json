    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "hast-util-to-html": "^9",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.55.1",
    "pi-mcp-adapter": "2.11.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.10",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "smol-toml": "1.7.0",
    "typebox": "^1.3.6",
    "uqr": "^0.1.3",
